# Optional: improves FRED reliability for high request volume
FRED_API_KEY=

# Optional: frontend API base URL for deployed web app
# Example: https://global-monitor-api.<subdomain>.workers.dev
VITE_API_BASE_URL=

# Optional: comma-separated list of repo names for release events
# Format: owner/repo,owner/repo
GITHUB_RELEASE_REPOS=openai/openai-cookbook,microsoft/typescript,vitejs/vite

# Optional: persistent Cloudflare KV cache binding name in wrangler.toml
# CACHE_KV=
